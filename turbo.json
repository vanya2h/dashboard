{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    }
  },
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "NODE_ENV",
    "DATABASE_URL",
    "BETTER_AUTH_API_KEY",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "UNSPLASH_ACCESS_KEY"
  ]
}
